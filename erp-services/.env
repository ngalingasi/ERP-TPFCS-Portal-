NODE_ENV=development
PORT=4500

# MySQL — ERP's own database
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=erp_portal_db

# JWT — ERP signs its own short-lived session tokens for the portal UI
JWT_SECRET=change_this_to_a_strong_random_secret
JWT_ACCESS_EXPIRATION_MINUTES=60
JWT_REFRESH_EXPIRATION_DAYS=7
